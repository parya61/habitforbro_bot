# Токен бота, полученный у @BotFather
BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyz1234567890

# Telegram ID владельца бота (узнать можно у @userinfobot)
ADMIN_ID=123456789

# Кодовое слово-приглашение, которое бот спросит при первом /start.
# Если оставить пустым — доступ контролируется только по ALLOWED_IDS/ADMIN_ID.
INVITE_CODE=придумай-секретное-слово

# Список разрешённых telegram_id через запятую (необязательно).
# Если пусто — пускаем всех, кто знает INVITE_CODE.
ALLOWED_IDS=

# Часовой пояс по умолчанию для новых пользователей
DEFAULT_TIMEZONE=Europe/Moscow

# Путь к файлу базы данных SQLite
DB_PATH=habits.db
